# Never commit real credentials. Copy this file to .env locally.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

TAVILY_API_KEY=

# API-key authentication with QWeather's legacy shared domains.
# These domains are being phased out; override them with your dedicated host later.
QWEATHER_API_KEY=
QWEATHER_WEATHER_BASE=https://devapi.qweather.com
QWEATHER_GEO_BASE=https://geoapi.qweather.com

AGENT_DATABASE_PATH=minimal_agent/agent.db
MAX_AGENT_STEPS=6
RECENT_MESSAGE_LIMIT=16
COMPACT_AFTER_MESSAGES=24
